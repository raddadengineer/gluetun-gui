+func isLegacyCNTLSError(err error) bool {
+	if err == nil {
+		return false
+	}
+	// Go 1.18+ message: "x509: certificate relies on legacy Common Name field, use SANs instead"
+	return strings.Contains(err.Error(), "x509: certificate relies on legacy Common Name field")
+}
